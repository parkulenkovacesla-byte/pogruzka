<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Вантажні перевезення | Крани-маніпулятори | Преміальна логістика</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 Free (безкоштовна версія з усіма базовими іконками) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background-color: #0A0C10; font-family: 'Inter', sans-serif; color: #EDEDED; line-height: 1.5; scroll-behavior: smooth; overflow-x: hidden; }
    :root { --gold: #C6A15B; --gold-light: #e0bc7c; --dark-bg: #0F1117; --card-bg: rgba(25, 30, 40, 0.7); --border-glow: rgba(198, 161, 91, 0.3); --cyber-glow: 0 0 10px rgba(198, 161, 91, 0.4); }
    .tech-grid-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; opacity: 0.05; background-image: repeating-linear-gradient(90deg, var(--gold) 0px, var(--gold) 1px, transparent 1px, transparent 150px), repeating-linear-gradient(0deg, var(--gold) 0px, var(--gold) 1px, transparent 1px, transparent 150px); }
    .glow-spot { position: fixed; width: 60vw; height: 60vw; background: radial-gradient(circle, rgba(198,161,91,0.08) 0%, rgba(198,161,91,0) 70%); border-radius: 50%; pointer-events: none; z-index: 0; top: 20%; right: -20%; }
    .glow-spot-2 { bottom: -30%; left: -20%; top: auto; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .animate-on-scroll { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .animate-on-scroll.visible { opacity: 1; transform: translateY(0); }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #1A1E26; }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 6px; }
    h1, h2, h3, .logo { font-family: 'Playfair Display', serif; font-weight: 500; }
    .section-title { font-size: 2.8rem; margin-bottom: 1rem; position: relative; display: inline-block; }
    .section-title::after { content: ''; position: absolute; bottom: -12px; left: 0; width: 70px; height: 3px; background: var(--gold); box-shadow: var(--cyber-glow); }
    .hero { position: relative; min-height: 100vh; background: linear-gradient(135deg, rgba(10, 12, 16, 0.92), rgba(0, 0, 0, 0.8)), url('main.jpg') center/cover no-repeat; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 2rem; z-index: 1; }
    .hero h1 { font-size: 3.5rem; font-weight: 700; margin-bottom: 1rem; animation: fadeInUp 0.8s ease; }
    .hero p { font-size: 1.3rem; max-width: 700px; margin: 1rem auto; color: #e0ddd5; animation: fadeInUp 0.8s ease 0.1s backwards; }
    @media (max-width: 768px) { .hero h1 { font-size: 2rem; } .section-title { font-size: 2rem; } }
    .logo-left { position: fixed; top: 20px; left: 25px; z-index: 1000; display: flex; align-items: center; gap: 10px; background: rgba(15, 17, 23, 0.7); backdrop-filter: blur(10px); padding: 8px 18px; border-radius: 50px; border: 1px solid var(--border-glow); }
    .logo-icon { font-size: 1.8rem; color: var(--gold); }
    .logo-text { font-family: 'Playfair Display', serif; font-weight: 600; font-size: 0.9rem; letter-spacing: 1px; }
    @media (max-width: 600px) { .logo-left { padding: 5px 12px; } .logo-icon { font-size: 1.3rem; } .logo-text { font-size: 0.7rem; } }
    .lang-nav { position: fixed; top: 20px; right: 25px; z-index: 1000; display: flex; gap: 12px; background: rgba(15, 17, 23, 0.7); backdrop-filter: blur(10px); padding: 8px 18px; border-radius: 50px; border: 1px solid var(--border-glow); }
    .lang-btn { background: transparent; border: none; color: #fff; font-weight: 600; font-size: 0.85rem; cursor: pointer; padding: 6px 14px; border-radius: 30px; transition: 0.2s; }
    .lang-btn.active { background: var(--gold); color: #0A0C10; }
    .btn-group { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; margin-top: 30px; animation: fadeInUp 0.8s ease 0.2s backwards; }
    .btn { padding: 14px 36px; font-size: 1rem; font-weight: 600; border-radius: 40px; cursor: pointer; transition: all 0.3s ease; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; }
    .btn-consult { background: var(--gold); color: #0A0C10; box-shadow: 0 6px 14px rgba(198, 161, 91, 0.3); }
    .btn-consult:hover { background: var(--gold-light); transform: translateY(-3px); }
    .btn-call { background: transparent; border: 1.5px solid var(--gold); color: white; }
    .btn-call:hover { background: var(--gold); color: #0A0C10; }
    .container { max-width: 1280px; margin: 0 auto; padding: 80px 24px; position: relative; z-index: 2; }
    .about-grid { display: flex; flex-wrap: wrap; gap: 40px; align-items: center; margin-top: 40px; }
    .about-text { flex: 1.2; font-size: 1.1rem; font-weight: 300; line-height: 1.6; color: #ddd8ce; }
    .services-list-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 40px; }
    .service-tag { background: rgba(198, 161, 91, 0.1); border: 1px solid rgba(198, 161, 91, 0.3); border-radius: 60px; padding: 14px 22px; text-align: center; font-weight: 500; transition: 0.3s; }
    .service-tag i { color: var(--gold); margin-right: 10px; }
    .service-tag:hover { background: rgba(198, 161, 91, 0.25); transform: translateY(-5px); border-color: var(--gold); }
    .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; margin-top: 50px; }
    .service-card { background: var(--card-bg); backdrop-filter: blur(6px); border: 1px solid rgba(198, 161, 91, 0.2); border-radius: 24px; padding: 2rem 1.5rem; text-align: center; transition: 0.3s ease; }
    .service-card:hover { transform: translateY(-10px); border-color: var(--gold); box-shadow: 0 20px 35px -12px rgba(0,0,0,0.6), var(--cyber-glow); }
    .service-icon { font-size: 3rem; color: var(--gold); margin-bottom: 1.2rem; transition: 0.3s; }
    .service-card:hover .service-icon { transform: scale(1.1); }
    .service-card h3 { font-size: 1.8rem; margin-bottom: 1rem; }
    .service-card p { font-weight: 300; color: #cbcbc2; }
    /* Галерея без підписів */
    .gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 28px; margin-top: 40px; }
    .gallery-item { position: relative; border-radius: 20px; overflow: hidden; transition: 0.4s; background: #1E232E; cursor: pointer; }
    .gallery-item img { width: 100%; height: 300px; object-fit: cover; display: block; transition: transform 0.5s ease, filter 0.4s; filter: brightness(0.85); }
    .gallery-item:hover { transform: translateY(-8px); box-shadow: 0 25px 35px -15px black, var(--cyber-glow); }
    .gallery-item:hover img { transform: scale(1.05); filter: brightness(1); }
    /* Без підписів — прибираємо caption повністю */
    footer { background: #080A0F; border-top: 1px solid var(--border-glow); padding: 48px 24px 32px; text-align: center; }
    .footer-phone { font-size: 1.6rem; font-weight: 600; margin: 20px 0; }
    .footer-phone a { color: var(--gold); text-decoration: none; }
    .messenger-links { display: flex; justify-content: center; gap: 30px; margin: 25px 0 20px; flex-wrap: wrap; }
    .messenger-links a { background: rgba(198, 161, 91, 0.12); border: 1px solid var(--border-glow); border-radius: 50px; padding: 12px 28px; text-decoration: none; color: #fff; font-weight: 500; display: inline-flex; align-items: center; gap: 12px; transition: 0.25s; }
    .messenger-links a:hover { background: var(--gold); color: #0A0C10; transform: translateY(-3px); }
    .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(12px); justify-content: center; align-items: center; z-index: 2000; }
    .modal-content { background: #151C26; border-radius: 32px; padding: 2rem; max-width: 450px; width: 90%; border: 1px solid var(--gold); }
    .modal-content input { width: 100%; padding: 14px; margin: 12px 0; background: #0F131C; border: 1px solid #2C3545; border-radius: 40px; color: white; }
    .modal-content button { background: var(--gold); color: #0A0C10; border: none; padding: 12px; width: 100%; border-radius: 40px; font-weight: bold; cursor: pointer; }
    .close-modal { float: right; font-size: 28px; cursor: pointer; color: var(--gold); }
    @media (max-width: 680px) { .btn-group { flex-direction: column; align-items: center; } .btn { width: 80%; justify-content: center; } }
  </style>
</head>
<body>
<div class="tech-grid-bg"></div>
<div class="glow-spot"></div>
<div class="glow-spot glow-spot-2"></div>
<div class="logo-left"><i class="fas fa-truck-fast logo-icon"></i><span class="logo-text">CARGO&CRANE</span></div>
<div class="lang-nav"><button class="lang-btn active" data-lang="uk">УКР</button><button class="lang-btn" data-lang="en">ENG</button></div>
<header class="hero" id="home"><h1 id="hero-title">Вантажоперевезення & Погрузочні роботи</h1><p id="hero-sub">Надійність. Швидкість. Професіоналізм 24/7</p>
<div class="btn-group"><button class="btn btn-consult" id="whatWeCanBtn"><i class="fas fa-cogs"></i> <span id="consultText">Що ми можемо</span></button><a href="tel:+380733132332" class="btn btn-call" id="callBtnLink"><i class="fas fa-phone-alt"></i> <span id="callText">Зв'язатися: 073 313 23 32</span></a></div>
</header>
<section class="container" id="whatWeCanSection" style="scroll-margin-top: 100px;"><h2 class="section-title" id="whatCanTitle">Що ми можемо</h2><div class="services-list-grid" id="servicesListGrid"></div></section>
<section class="container" id="about"><h2 class="section-title" id="aboutTitle">Про компанію</h2><div class="about-grid"><div class="about-text" id="aboutText">Потужний автопарк, досвідчені водії-оператори та індивідуальний підхід до кожного клієнта. Перевезення вантажів будь-якої складності Одесою, областю та за її межами. Працюємо з фізичними та юридичними особами.</div><div style="flex:0.8; text-align:center;"><i class="fas fa-truck-ramp-box" style="font-size: 5rem; color: var(--gold); opacity: 0.9;"></i></div></div></section>
<section class="container" id="services"><h2 class="section-title" id="servicesTitle">Наші послуги</h2><div class="services-grid" id="servicesGrid"></div></section>
<section class="container" id="gallerySection"><h2 class="section-title" id="galleryTitle">Галерея</h2><div class="gallery" id="galleryContainer"></div></section>
<footer><div class="footer-phone"><i class="fas fa-mobile-alt" style="color: var(--gold);"></i> <a href="tel:+380733132332" id="footerPhoneLink">073 313 23 32</a></div><div class="messenger-links" id="messengerLinks"></div><p id="footerText">© 2025 Вантажоперевезення & Крани-маніпулятори — преміальна логістика</p></footer>
<div id="consultModal" class="modal"><div class="modal-content"><span class="close-modal" id="closeModalBtn">&times;</span><h3 id="modalTitle">Замовити дзвінок</h3><p id="modalSub">Ми передзвонимо вам за 15 хвилин</p><input type="text" id="userName" placeholder="Ваше ім'я"><input type="tel" id="userPhone" placeholder="Номер телефону"><button id="submitConsultBtn">Надіслати</button></div></div>
<script>
  const uniqueServices = { uk: ["Перевезення на будь-які відстані","Перевезення власним автотранспортом","Вантажоперевезення в місті та області","Послуги маніпулятора в любий час","Вантажні перевезення","Машини з краном-маніпулятором","Крани-маніпулятори будь-якої вантажопідйомності","Вантажне таксі","Доставка вантажів","Попутний вантаж","Кран-маніпулятор цілодобово","Перевезення будівельних матеріалів","Оренда спецтехніки"], en: ["Transportation over any distance","Transportation by our own fleet","Cargo transportation within city & region","Manipulator services anytime","Freight transportation","Trucks with crane manipulator","Cranes of any lifting capacity","Freight taxi","Goods delivery","Backhaul cargo","24/7 manipulator crane","Construction materials transport","Special equipment rental"] };
  
  // Основні послуги з емодзі крана
  const mainServices = { 
    uk: [
      { title: "Вантажоперевезення", desc: "Повний спектр логістики: від дрібних партій до великогабаритних модулів. Контроль на кожному етапі.", icon: "fa-truck" },
      { title: "Кран-маніпулятор", desc: "Точна робота на об'єкті. Вантажність до 25 тонн, виліт стріли до 22 метрів. Оперативний виїзд.", icon: "🏗️" },
      { title: "Вантажні роботи", desc: "Навантаження/розвантаження, переміщення техніки, складські послуги. Мінімізуємо час простою.", icon: "fa-dolly" }
    ], 
    en: [
      { title: "Cargo Transport", desc: "Full logistics range from small batches to oversized modules. Control at every stage.", icon: "fa-truck" },
      { title: "Crane Manipulator", desc: "Precise work on site. Capacity up to 25 tons, boom reach up to 22 m. Quick response.", icon: "🏗️" },
      { title: "Loading Services", desc: "Loading/unloading, equipment moving, warehousing. Minimize downtime.", icon: "fa-dolly" }
    ] 
  };
  
  let currentLang = 'uk';
  function applyLanguage(lang) {
    currentLang = lang; const tMain = mainServices[lang]; const tUnique = uniqueServices[lang];
    document.getElementById("hero-title").innerText = (lang === 'uk') ? "Вантажоперевезення & Погрузочні роботи" : "Freight & Loading Services";
    document.getElementById("hero-sub").innerText = (lang === 'uk') ? "Надійність. Швидкість. Професіоналізм 24/7" : "Reliability. Speed. Professionalism 24/7";
    document.getElementById("consultText").innerText = (lang === 'uk') ? "Що ми можемо" : "What we offer";
    document.getElementById("callText").innerText = (lang === 'uk') ? "Зв'язатися: 073 313 23 32" : "Contact: 073 313 23 32";
    document.getElementById("whatCanTitle").innerText = (lang === 'uk') ? "Що ми можемо" : "What we offer";
    document.getElementById("aboutTitle").innerText = (lang === 'uk') ? "Про компанію" : "About Us";
    document.getElementById("aboutText").innerHTML = (lang === 'uk') ? "Потужний автопарк, досвідчені водії-оператори та індивідуальний підхід до кожного клієнта. Перевезення вантажів будь-якої складності Одесою, областю та за її межами. Працюємо з фізичними та юридичними особами." : "Powerful fleet, experienced driver-operators, and individual approach to each client. Cargo transportation of any complexity in Odesa, region and beyond.";
    document.getElementById("servicesTitle").innerText = (lang === 'uk') ? "Наші послуги" : "Our Services";
    document.getElementById("galleryTitle").innerText = (lang === 'uk') ? "Галерея" : "Gallery";
    document.getElementById("footerText").innerText = (lang === 'uk') ? "© 2025 Вантажоперевезення & Крани-маніпулятори — преміальна логістика" : "© 2025 Freight & Crane Manipulators — premium logistics";
    const listGrid = document.getElementById("servicesListGrid"); listGrid.innerHTML = "";
    tUnique.forEach(item => { const div = document.createElement("div"); div.className = "service-tag"; div.innerHTML = `<i class="fas fa-check-circle"></i> ${item}`; listGrid.appendChild(div); });
    const servicesGrid = document.getElementById("servicesGrid"); servicesGrid.innerHTML = "";
    tMain.forEach(serv => { 
      const card = document.createElement("div"); 
      card.className = "service-card"; 
      const iconHtml = (serv.icon === "🏗️") ? `<div class="service-icon" style="font-size: 3rem;">🏗️</div>` : `<div class="service-icon"><i class="fas ${serv.icon}"></i></div>`;
      card.innerHTML = `${iconHtml}<h3>${serv.title}</h3><p>${serv.desc}</p>`; 
      servicesGrid.appendChild(card); 
    });
    document.querySelectorAll(".lang-btn").forEach(btn => { if (btn.getAttribute("data-lang") === lang) btn.classList.add("active"); else btn.classList.remove("active"); });
    // Оновлення галереї не потребує підписів – просто перезавантажуємо фото
    initGallery(); // оновлюємо галерею при зміні мови (без підписів)
  }
  
  // ГАЛЕРЕЯ: tech1, tech2, tech3, tech6, tech7, tech8 (6 фото, БЕЗ ПІДПИСІВ)
  function initGallery() { 
    const galleryContainer = document.getElementById("galleryContainer"); 
    galleryContainer.innerHTML = ""; 
    const images = ["tech1.jpg", "tech2.jpg", "tech3.jpg", "tech6.jpg", "tech7.jpg", "tech8.jpg"]; 
    for (let i = 0; i < images.length; i++) { 
      const imgName = images[i]; 
      const itemDiv = document.createElement("div"); 
      itemDiv.className = "gallery-item"; 
      // Без жодного текстового підпису — тільки фото
      itemDiv.innerHTML = `<img src="${imgName}" alt="Gallery ${i+1}" loading="lazy" onerror="this.src='https://placehold.co/600x400/2C3545/C6A15B?text=${imgName}'">`; 
      galleryContainer.appendChild(itemDiv); 
    } 
  }
  
  function initMessengers() { document.getElementById("messengerLinks").innerHTML = `<a href="https://wa.me/380733132332" target="_blank"><i class="fab fa-whatsapp"></i> WhatsApp</a><a href="https://t.me/380733132332" target="_blank"><i class="fab fa-telegram-plane"></i> Telegram</a><a href="viber://chat?number=380733132332" target="_blank"><i class="fab fa-viber"></i> Viber</a>`; }
  
  // Анімація при скролі
  const animatedElements = document.querySelectorAll('.service-card, .service-tag, .gallery-item, .about-grid'); 
  const observer = new IntersectionObserver((entries) => { entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); }); }, { threshold: 0.1 }); 
  animatedElements.forEach(el => { el.classList.add('animate-on-scroll'); observer.observe(el); });
  
  document.getElementById("whatWeCanBtn").addEventListener("click", () => { document.getElementById("whatWeCanSection").scrollIntoView({ behavior: "smooth", block: "start" }); });
  
  const modal = document.getElementById("consultModal"); const closeModalSpan = document.getElementById("closeModalBtn"); const submitConsult = document.getElementById("submitConsultBtn");
  window.closeModal = () => { if(modal) modal.style.display = "none"; }; if(closeModalSpan) closeModalSpan.addEventListener("click", closeModal); window.addEventListener("click", (e) => { if (e.target === modal) modal.style.display = "none"; });
  if(submitConsult) { submitConsult.addEventListener("click", () => { const name = document.getElementById("userName")?.value.trim(); const phone = document.getElementById("userPhone")?.value.trim(); if (!name || !phone) { alert(currentLang === 'uk' ? "Заповніть ім'я та телефон" : "Fill in name and phone"); return; } alert(currentLang === 'uk' ? "Дякуємо! Менеджер зателефонує." : "Thank you! Manager will call."); modal.style.display = "none"; if(document.getElementById("userName")) document.getElementById("userName").value = ""; if(document.getElementById("userPhone")) document.getElementById("userPhone").value = ""; }); }
  
  document.querySelectorAll(".lang-btn").forEach(btn => { btn.addEventListener("click", () => { applyLanguage(btn.getAttribute("data-lang")); }); });
  
  initGallery(); 
  initMessengers(); 
  applyLanguage('uk');
</script>
</body>
</html>
